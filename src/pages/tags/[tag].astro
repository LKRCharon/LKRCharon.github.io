---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TagBadge from '../../components/TagBadge.astro';
import { SITE_TITLE } from '../../consts';
import { type CollectionEntry, getCollection } from 'astro:content';
import { normalizeTag, tagToSlug } from '../../utils/tags';

interface TagPageProps {
	tag: string;
	posts: CollectionEntry<'blog'>[];
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const byTag = new Map<string, CollectionEntry<'blog'>[]>();

	for (const post of posts) {
		for (const rawTag of post.data.tags) {
			const tag = normalizeTag(rawTag);
			if (!tag) continue;
			const list = byTag.get(tag) ?? [];
			list.push(post);
			byTag.set(tag, list);
		}
	}

	return [...byTag.entries()].map(([tag, relatedPosts]) => ({
		params: { tag: tagToSlug(tag) },
		props: {
			tag,
			posts: relatedPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { tag, posts } = Astro.props as TagPageProps;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`#${tag} | ${SITE_TITLE}`} description={`Posts tagged with ${tag}`} />
	</head>
	<body>
		<Header />
		<main class="page-shell space-y-6">
			<section class="border-y border-line-soft/80 py-8 sm:py-10">
				<a class="inline-flex items-center gap-2 text-sm font-medium text-muted transition hover:text-text" href="/tags">
					<span aria-hidden="true">←</span>
					All tags
				</a>
				<div class="mt-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
					<div class="space-y-4">
						<TagBadge tag={tag} size="md" />
						<p class="section-subtitle max-w-3xl">
							Posts filed under this topic, gathered in chronological order.
						</p>
					</div>
					<span class="meta-pill">{posts.length} posts</span>
				</div>
			</section>
			<ul class="list-none divide-y divide-line-soft border-y border-line-soft p-0">
				{
					posts.map((post) => (
						<li class="py-6 sm:py-7">
							<a class="group block space-y-4" href={`/blog/${post.id}/`}>
								<span class="meta-pill">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<div class="space-y-3">
									<h2 class="text-[1.18rem] font-semibold tracking-[-0.03em] text-text transition group-hover:text-accent sm:text-[1.3rem]">
										{post.data.title}
									</h2>
									<p class="text-sm leading-7 text-muted sm:text-[0.98rem]">
										{post.data.description}
									</p>
								</div>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
