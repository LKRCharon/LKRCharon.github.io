---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import TagBadge from '../../components/TagBadge.astro';
import { normalizeTag, tagToSlug } from '../../utils/tags';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();

for (const post of posts) {
	for (const rawTag of post.data.tags) {
		const tag = normalizeTag(rawTag);
		if (!tag) continue;
		tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
	}
}

const tags = [...tagCounts.entries()]
	.map(([tag, count]) => ({ tag, count, slug: tagToSlug(tag) }))
	.sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag, 'zh-CN'));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags | ${SITE_TITLE}`} description="Browse posts by tags" />
	</head>
	<body>
		<Header />
		<main class="page-shell space-y-6">
			<section class="border-y border-line-soft/80 py-8 sm:py-10">
				<p class="eyebrow">Taxonomy</p>
				<div class="mt-3 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
					<div class="space-y-3">
						<h1 class="section-heading">Tags</h1>
						<p class="section-subtitle max-w-3xl">
							Browse the archive through recurring topics, tooling clusters, and long-lived themes.
						</p>
					</div>
					<span class="meta-pill">{tags.length} tags</span>
				</div>
			</section>
			{
				tags.length > 0 ? (
					<ul class="flex list-none flex-wrap gap-3 border-y border-line-soft py-6 sm:py-8">
						{tags.map((item) => (
							<li>
								<TagBadge tag={item.tag} href={`/tags/${item.slug}/`} count={item.count} />
							</li>
						))}
					</ul>
				) : (
					<section class="border-y border-line-soft py-6 text-muted sm:py-8">No tags yet.</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>
