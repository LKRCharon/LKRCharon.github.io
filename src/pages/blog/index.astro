---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import TagBadge from '../../components/TagBadge.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell space-y-6">
			<section class="surface-panel p-6 sm:p-8">
				<p class="eyebrow">Archive</p>
				<div class="mt-3 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
					<div class="space-y-3">
						<h1 class="section-heading">All posts</h1>
						<p class="section-subtitle max-w-3xl">
							A running archive of notes on distributed systems, tooling, engineering workflow, and
							research-facing writing.
						</p>
					</div>
					<span class="meta-pill">{posts.length} posts</span>
				</div>
			</section>
			<section>
				<ul class="grid list-none gap-4 p-0">
					{
						posts.map((post) => (
							<li class="surface-card surface-card-interactive p-5 sm:p-6">
								<a class="group block space-y-4" href={`/blog/${post.id}/`}>
									<span class="meta-pill">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<div class="space-y-3">
										<h2 class="text-[1.18rem] font-semibold tracking-[-0.03em] text-text transition group-hover:text-accent sm:text-[1.32rem]">
											{post.data.title}
										</h2>
										<p class="text-sm leading-7 text-muted sm:text-[0.98rem]">
											{post.data.description}
										</p>
									</div>
								</a>
								{
									post.data.tags.length > 0 && (
										<div class="mt-4 flex flex-wrap gap-2">
											{post.data.tags.map((tag) => (
												<TagBadge tag={tag} />
											))}
										</div>
									)
								}
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
