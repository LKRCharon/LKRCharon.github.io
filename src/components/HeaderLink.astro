---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const isActive = href === pathname || href === '/' + (subpath?.[0] || '');
---

<a
	href={href}
	class:list={[
		'inline-flex items-center rounded-xl px-3 py-2 text-sm font-medium tracking-[-0.01em] transition duration-200',
		isActive
			? 'border border-line-soft bg-white text-text shadow-[0_10px_22px_-18px_rgba(31,41,55,0.28)]'
			: 'text-muted hover:bg-white/80 hover:text-text',
		className,
	]}
	{...props}
>
	<slot />
</a>
