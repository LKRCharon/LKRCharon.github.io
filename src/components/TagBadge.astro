---
import { getTagBadgeStyle, tagToSlug } from '../utils/tags';

interface Props {
	tag: string;
	count?: number;
	href?: string;
	showHash?: boolean;
	size?: 'sm' | 'md';
}

const { tag, count, href = `/tags/${tagToSlug(tag)}/`, showHash = true, size = 'sm' } = Astro.props;
const label = showHash ? `#${tag}` : tag;
const style = getTagBadgeStyle(tag);
---

<a
	class:list={[
		'inline-flex items-center gap-2 rounded-full border border-gray-950/10 bg-white text-gray-900 shadow-[inset_0_1px_0_rgba(255,255,255,0.9)] transition hover:border-gray-950/15 hover:bg-gray-50 hover:text-gray-950',
		size === 'md' ? 'px-3 py-1.5 text-sm/6 font-medium' : 'px-2.5 py-1 text-xs/6 font-medium',
	]}
	href={href}
	style={style}
>
	<span
		class:list={[
			'rounded-full bg-[var(--tag-dot-color)]',
			size === 'md' ? 'size-2.5' : 'size-1.5',
		]}
		aria-hidden="true"
	></span>
	<span class="whitespace-nowrap text-current">{label}</span>
	{
		count !== undefined && (
			<span class="rounded-full bg-gray-950/5 px-1.5 py-0.5 text-[0.7rem] font-semibold text-gray-600">
				{count}
			</span>
		)
	}
</a>
