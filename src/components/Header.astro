---
import HeaderLink from './HeaderLink.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<header class="border-b border-line-soft/80 bg-canvas/90">
	<nav class="mx-auto flex max-w-6xl flex-wrap items-center gap-4 px-4 py-4 sm:px-6 lg:px-8">
		<a href="/" class="min-w-0 flex-1 sm:flex-none">
			<div class="flex flex-col gap-1">
				<span class="eyebrow">Notes & Experiments</span>
				<span class="text-base font-semibold tracking-[-0.03em] text-text">{SITE_TITLE}</span>
				<span class="hidden text-sm text-muted lg:block">{SITE_DESCRIPTION}</span>
			</div>
		</a>
		<div class="hidden min-w-0 flex-1 justify-center md:flex">
			<div class="flex items-center gap-1 rounded-2xl border border-line-soft bg-white/78 p-1 shadow-[0_16px_30px_-26px_rgba(31,41,55,0.24)]">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/tags">Tags</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>
		</div>
		<div class="ml-auto flex items-center gap-2">
			<a
				class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-line-soft bg-white/84 text-muted shadow-[0_10px_24px_-20px_rgba(31,41,55,0.28)] transition hover:-translate-y-0.5 hover:text-text"
				href="https://github.com/LKRCharon"
				target="_blank"
				rel="noopener noreferrer"
			>
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg>
			</a>
		</div>
		<div class="flex w-full flex-wrap gap-2 md:hidden">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/tags">Tags</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
